# =============================================================================
# HolePunch — .gitignore
# =============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.env
.env.*
venv/
.venv/
*.egg-info/
dist/
build/

# PyInstaller
*.spec

# ── Go ────────────────────────────────────────────────────────────────────────
# Test artifacts
*.test
*.out
coverage.out
coverage.html

# Vendor directory (we use go.sum instead)
core/vendor/

# Local Go build output (not inside bin/)
core/holepunch
core/holepunch.exe
core/signal-server
core/signal-server.exe

# ── Compiled binaries (bin/) ──────────────────────────────────────────────────
# All compiled binaries are git-ignored; build them with scripts/build.sh
# The .gitkeep file is explicitly UN-ignored to preserve the empty directory.
bin/*
!bin/.gitkeep

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── Docker ────────────────────────────────────────────────────────────────────
# Local docker-compose overrides
docker-compose.override.yml

# ── Secrets / local config ────────────────────────────────────────────────────
# Local app config (signal URL, etc.) — generated by the GUI Settings page
config.json

*.pem
*.key
*.p12
.secrets
secrets.json
